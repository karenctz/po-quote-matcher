# Copy this file to .streamlit/secrets.toml for local use (already
# gitignored, so real values never get committed) -- or, for the hosted
# deployment, paste these into the app's Settings -> Secrets box on
# Streamlit Community Cloud instead. Never commit real secrets.

# Optional: gates the whole app behind a shared password. Leave unset (or
# delete this line) to run with no password prompt -- e.g. for local-only use.
app_password = "changeme"

# Optional: enables OCR for scanned/signed customer PDFs that have no text
# layer, via a Power Automate flow backed by AI Builder (see README for the
# flow spec to build). Leave both unset to skip OCR -- scanned documents will
# just show "no line items detected, add rows manually" instead.
power_automate_url = "https://prod-00.region.logic.azure.com:443/workflows/xxxx/triggers/manual/paths/invoke?api-version=2016-06-01&sig=xxxx"
power_automate_secret = "changeme"
